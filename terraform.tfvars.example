# Example Terraform variables file
# Copy this to terraform.tfvars and fill in your actual values

# ===== DATABRICKS CONFIGURATION =====
# Required: Your Databricks Account ID (format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
databricks_account_id = "your-databricks-account-id-here"

# OAuth authentication will be used - no token needed
# You'll authenticate via browser when running 'databricks auth login'

# Optional: Databricks host (usually don't need to change this)
databricks_host = "https://accounts.cloud.databricks.com"

# ===== AWS CONFIGURATION =====
prefix                    = "your-prefix"
aws_region               = "us-west-2"
vpc_cidr_block          = "10.0.0.0/16"
databricks_workspace_name = "your-workspace-name"

# ===== DATABRICKS WORKSPACE CONFIGURATION =====
databricks_pricing_tier = "ENTERPRISE"

# ===== UNITY CATALOG CONFIGURATION =====
create_unity_catalog_metastore = false
# unity_catalog_metastore_name = "your-metastore-name"  # Not needed when using existing
existing_metastore_id = "your-existing-metastore-id-here"

# ===== RESOURCE TAGS =====
default_tags = {
  Project     = "Databricks Infrastructure"
  ManagedBy   = "Terraform"
  Environment = "production"
  Owner       = "your-name"
}